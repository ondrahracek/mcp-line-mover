{
  "name": "@scope/mcp-line-mover",
  "version": "0.1.0",
  "description": "MCP stdio server for moving line ranges between files without copying content through agent context",
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ondrahracek/mcp-line-mover.git"
  },
  "homepage": "https://github.com/ondrahracek/mcp-line-mover#readme",
  "bugs": {
    "url": "https://github.com/ondrahracek/mcp-line-mover/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "refactor",
    "move-lines"
  ],
  "type": "module",
  "bin": {
    "mcp-line-mover": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "SPEC.md",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "lint": "eslint src test",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test && npm run test:e2e"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
